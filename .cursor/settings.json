{
  "projectName": "traffic-danger-alert",
  "framework": "react-native-expo",
  "language": "typescript",
  "description": "一個使用 React Native Expo 開發的交通危險警示 App，可以偵測使用者是否接近危險路段並提供警示。",
  "features": [
    "即時位置追蹤",
    "危險路段警示",
    "背景運作支援",
    "自定義警示距離",
    "震動和聲音提醒"
  ],
  "dependencies": {
    "expo": "latest",
    "expo-location": "latest",
    "expo-background-fetch": "latest",
    "expo-vibration": "latest",
    "react-native": "latest",
    "typescript": "latest"
  },
  "structure": {
    "src": {
      "components": "UI 元件",
      "screens": "畫面",
      "services": "服務層",
      "utils": "工具函數",
      "types": "TypeScript 型別定義",
      "constants": "常數定義",
      "assets": "靜態資源"
    }
  }
}
